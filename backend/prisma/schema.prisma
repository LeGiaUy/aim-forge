// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentMethod {
  COD
  VNPAY
}

enum DiscountType {
  PERCENT
  FIXED
}

//////////////////////
// USER & RBAC
//////////////////////

model User {
  user_id    Int       @id @default(autoincrement())
  username   String    @unique
  email      String    @unique
  password   String
  avatar     String?
  phone      String?
  address    String?
  status     String    @default("ACTIVE")
  last_login DateTime?
  created_at DateTime  @default(now())

  roles  UserRole[]
  cart   Cart?
  orders Order[]
}

model Role {
  role_id   Int    @id @default(autoincrement())
  role_name String @unique

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  permission_id   Int    @id @default(autoincrement())
  permission_name String @unique

  roles RolePermission[]
}

model UserRole {
  user_id Int
  role_id Int

  user User @relation(fields: [user_id], references: [user_id])
  role Role @relation(fields: [role_id], references: [role_id])

  @@id([user_id, role_id])
}

model RolePermission {
  role_id         Int
  permission_id Int

  role       Role       @relation(fields: [role_id], references: [role_id])
  permission Permission @relation(fields: [permission_id], references: [permission_id])

  @@id([role_id, permission_id])
}

//////////////////////
// PRODUCT CORE
//////////////////////

model Category {
  category_id Int     @id @default(autoincrement())
  name        String
  image_url   String?

  products   Product[]
  attributes Attribute[]
}

model Brand {
  brand_id  Int     @id @default(autoincrement())
  name      String
  country   String?
  image_url String?

  products Product[]
}

model Product {
  product_id  Int      @id @default(autoincrement())
  name        String
  description String?
  /// Giá tham chiếu cho listing (từ / min); giá thực tế theo ProductVariant.price
  price       Decimal?

  category_id Int?
  brand_id    Int?
  is_active   Boolean  @default(true)

  category Category? @relation(fields: [category_id], references: [category_id])
  brand    Brand?    @relation(fields: [brand_id], references: [brand_id])

  variants           ProductVariant[]
  specs              ProductAttributeValue[]
  product_options    ProductOption[]
  discount_products  DiscountProduct[]
}

//////////////////////
// VARIANT OPTIONS (flexible axes)
//////////////////////

model ProductOption {
  option_id   Int @id @default(autoincrement())
  product_id  Int
  /// Tên tuỳ chọn hiển thị (vd: Color, Size)
  name        String
  sort_order  Int @default(0)

  product       Product              @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  option_values ProductOptionValue[]

  @@index([product_id])
}

model ProductOptionValue {
  option_value_id Int    @id @default(autoincrement())
  option_id       Int
  value           String
  sort_order      Int    @default(0)

  option                ProductOption        @relation(fields: [option_id], references: [option_id], onDelete: Cascade)
  variant_option_values VariantOptionValue[]
  images                OptionValueImage[]

  @@index([option_id])
}

//////////////////////
// VARIANT (SKU)
//////////////////////

model ProductVariant {
  variant_id  Int @id @default(autoincrement())
  product_id  Int

  sku           String?  @unique
  stock         Int      @default(0)
  /// Giá bán SKU (Shopify-style)
  price         Decimal  @default(0)
  /// Giá niêm yết so với giá bán (gạch ngang UI)
  compare_price Decimal?
  /// Giá vốn / COGS (tùy chọn)
  cost_price    Decimal?
  is_active     Boolean  @default(true)

  option_value_signature String?
  options_cache          Json?

  product Product @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  variant_option_values VariantOptionValue[]
  cart_items            CartItem[]
  order_items           OrderItem[]
  discount_variants     DiscountVariant[]

  @@index([product_id])
  @@unique([product_id, option_value_signature])
}

model VariantOptionValue {
  variant_id      Int
  option_value_id Int

  variant      ProductVariant     @relation(fields: [variant_id], references: [variant_id], onDelete: Cascade)
  option_value ProductOptionValue @relation(fields: [option_value_id], references: [option_value_id], onDelete: Restrict)

  @@id([variant_id, option_value_id])
  @@index([option_value_id])
}

//////////////////////
// DISCOUNT (promotions layer)
//////////////////////

model Discount {
  discount_id Int          @id @default(autoincrement())
  name        String
  type        DiscountType
  value       Decimal
  start_at    DateTime
  end_at      DateTime?
  is_active   Boolean      @default(true)
  created_at  DateTime     @default(now())

  products DiscountProduct[]
  variants DiscountVariant[]

  @@index([start_at])
  @@index([end_at])
}

model DiscountProduct {
  discount_id Int
  product_id  Int

  discount Discount @relation(fields: [discount_id], references: [discount_id], onDelete: Cascade)
  product  Product  @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  @@id([discount_id, product_id])
  @@index([product_id])
}

model DiscountVariant {
  discount_id Int
  variant_id  Int

  discount Discount       @relation(fields: [discount_id], references: [discount_id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variant_id], references: [variant_id], onDelete: Cascade)

  @@id([discount_id, variant_id])
  @@index([variant_id])
}

//////////////////////
// EAV
//////////////////////

model Attribute {
  attribute_id Int    @id @default(autoincrement())
  name         String
  category_id  Int?

  category Category? @relation(fields: [category_id], references: [category_id])

  values         AttributeValue[]
  product_values ProductAttributeValue[]
}

model AttributeValue {
  value_id     Int    @id @default(autoincrement())
  attribute_id Int
  value        String

  attribute Attribute @relation(fields: [attribute_id], references: [attribute_id])
}

model ProductAttributeValue {
  product_id   Int
  attribute_id Int
  value        String

  product   Product   @relation(fields: [product_id], references: [product_id])
  attribute Attribute @relation(fields: [attribute_id], references: [attribute_id])

  @@id([product_id, attribute_id])
}

//////////////////////
// IMAGES (theo giá trị tùy chọn — vd. một màu nhiều ảnh)
//////////////////////

model OptionValueImage {
  image_id         Int @id @default(autoincrement())
  option_value_id Int

  image_url  String
  is_main    Boolean @default(false)
  sort_order Int     @default(0)

  option_value ProductOptionValue @relation(fields: [option_value_id], references: [option_value_id], onDelete: Cascade)

  @@index([option_value_id])
}

//////////////////////
// CART
//////////////////////

model Cart {
  cart_id Int @id @default(autoincrement())
  user_id Int @unique

  user  User       @relation(fields: [user_id], references: [user_id])
  items CartItem[]
}

model CartItem {
  cart_id    Int
  variant_id Int
  quantity   Int

  cart    Cart           @relation(fields: [cart_id], references: [cart_id])
  variant ProductVariant @relation(fields: [variant_id], references: [variant_id], onDelete: Cascade)

  @@id([cart_id, variant_id])
}

//////////////////////
// ORDER
//////////////////////

model Order {
  order_id Int @id @default(autoincrement())
  user_id  Int

  created_at DateTime    @default(now())
  status     OrderStatus @default(PENDING)
  total      Decimal
  address    String
  is_paid    Boolean     @default(false)

  user     User        @relation(fields: [user_id], references: [user_id])
  items    OrderItem[]
  payments Payment[]
}

model OrderItem {
  order_id   Int
  variant_id Int

  price    Decimal
  quantity Int

  order   Order          @relation(fields: [order_id], references: [order_id])
  variant ProductVariant @relation(fields: [variant_id], references: [variant_id], onDelete: Restrict)

  @@id([order_id, variant_id])
}

//////////////////////
// PAYMENT
//////////////////////

model Payment {
  payment_id Int @id @default(autoincrement())
  order_id   Int

  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  amount         Decimal
  currency       String        @default("VND")
  transaction_id String?
  response_code  String?
  paid_at        DateTime?
  created_at     DateTime      @default(now())

  order Order @relation(fields: [order_id], references: [order_id])

  @@index([transaction_id])
  @@unique([order_id, method])
}
